############################################
# Python
############################################
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

############################################
# Virtual Environment
############################################
venv/
env/
.venv/

############################################
# Django
############################################
*.log
db.sqlite3
media/
staticfiles/

############################################
**/migrations/*
!**/migrations/
!**/migrations/__init__.py
**/migrations/__pycache__/
**/migrations/__pycache__/models.cpython-313.pyc
**/migrations/__pycache__/serializers.cpython-313.pyc

############################################
# Environment Variables
# ✅ Keep .env.example so devs know what
#    variables are needed.
############################################
.env
.env.local
.env.production
.env.staging
# Do NOT ignore .env.example

############################################
# VS Code
############################################
.vscode/

############################################
